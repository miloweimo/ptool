{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "webviews": ["*"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-download-write-recursive",
    "fs:allow-document-write-recursive",
    "fs:allow-picture-write-recursive",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "content://**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "content://**" }
      ]
    }
  ]
}
